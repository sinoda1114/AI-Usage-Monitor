{
  "manifest_version": 3,
  "name": "AI Usage Monitor",
  "version": "0.1.0",
  "description": "Collect visible subscription usage from Cursor, Codex, and Claude pages into the local dashboard.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "AI Usage Monitor"
  },
  "options_page": "options.html",
  "permissions": ["alarms", "storage", "tabs"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://*.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://cursor.com/*/dashboard/spending*",
        "https://cursor.com/dashboard/spending*",
        "https://chatgpt.com/codex/cloud/settings/analytics*",
        "https://claude.ai/settings/usage*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://127.0.0.1/*",
        "http://localhost/*",
        "https://*.vercel.app/*"
      ],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
